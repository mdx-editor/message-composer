{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["es2023", "dom", "dom.iterable"],
    "moduleDetection": "force",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "types": ["node", "react", "react-dom"],
    "paths": {
      "@mdxeditor/message-composer": ["./src/index.ts"],
      "@mdxeditor/message-composer/plugins/agent-settings": ["./src/plugins/agent-settings/index.ts"],
      "@mdxeditor/message-composer/plugins/attachments": ["./src/plugins/attachments/index.ts"],
      "@mdxeditor/message-composer/plugins/formatting": ["./src/plugins/formatting/index.tsx"],
      "@mdxeditor/message-composer/plugins/mentions": ["./src/plugins/mentions/index.ts"],
      "@mdxeditor/message-composer/plugins/slash-commands": ["./src/plugins/slash-commands/index.tsx"]
    },
    "strict": true,
    "noUnusedLocals": true,
    "declaration": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["src", "tests", "registry", "vite.config.ts"]
}
