{
  "name": "@mdxeditor/message-composer",
  "version": "0.0.0",
  "description": "A React message composer component for chat and AI agent interfaces.",
  "homepage": "https://mdx-editor.github.io/message-composer/",
  "bugs": {
    "url": "https://github.com/mdx-editor/message-composer/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdx-editor/message-composer.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./plugins/agent-settings": "./dist/plugins/agent-settings.mjs",
    "./plugins/attachments": "./dist/plugins/attachments.mjs",
    "./plugins/formatting": "./dist/plugins/formatting.mjs",
    "./plugins/mentions": "./dist/plugins/mentions.mjs",
    "./plugins/slash-commands": "./dist/plugins/slash-commands.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "build:registry": "shadcn build registry.json --output build/r",
    "dev": "vp pack --watch",
    "dev:stories": "ladle serve --viteConfig ladle.vite.config.ts",
    "test": "vp test",
    "check": "vp check",
    "build:stories": "ladle build --viteConfig ladle.vite.config.ts",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@lexical/code": "0.45.0",
    "@lexical/link": "0.45.0",
    "@lexical/list": "0.45.0",
    "@lexical/markdown": "0.45.0",
    "@lexical/react": "0.45.0",
    "@lexical/rich-text": "0.45.0",
    "@lexical/selection": "0.45.0",
    "@virtuoso.dev/reactive-engine-core": "0.0.8",
    "@virtuoso.dev/reactive-engine-react": "0.2.3",
    "lexical": "0.45.0",
    "mdast-util-from-markdown": "2.0.3",
    "mdast-util-gfm-strikethrough": "2.0.0",
    "mdast-util-to-markdown": "2.1.2",
    "micromark-extension-gfm-strikethrough": "2.1.0"
  },
  "devDependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@ladle/react": "^5.1.1",
    "@lexical/headless": "0.45.0",
    "@lexical/html": "0.45.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/mdast": "4.0.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "@vitejs/plugin-react": "6.0.2",
    "clsx": "2.1.1",
    "happy-dom": "20.10.2",
    "playwright": "1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "4.11.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  },
  "packageManager": "pnpm@11.6.0"
}
