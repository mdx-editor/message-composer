{
  "name": "@mdxeditor/message-composer",
  "version": "0.0.0",
  "description": "A React message composer component for chat and AI agent interfaces.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "dev:stories": "ladle serve --viteConfig ladle.vite.config.ts",
    "test": "vp test",
    "check": "vp check",
    "build:stories": "ladle build --viteConfig ladle.vite.config.ts",
    "prepublishOnly": "vp run build",
    "prepare": "vp config"
  },
  "dependencies": {
    "@lexical/code": "0.45.0",
    "@lexical/link": "0.45.0",
    "@lexical/list": "0.45.0",
    "@lexical/markdown": "0.45.0",
    "@lexical/react": "0.45.0",
    "@lexical/rich-text": "0.45.0",
    "@virtuoso.dev/reactive-engine-core": "0.0.8",
    "@virtuoso.dev/reactive-engine-react": "0.2.3",
    "lexical": "0.45.0"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "@vitejs/plugin-react": "6.0.2",
    "happy-dom": "20.10.2",
    "playwright": "1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  },
  "packageManager": "pnpm@11.6.0"
}
